{
  "description": "Omniscitus: automatic blueprint tracking on file changes",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/blueprint-tracker.cjs\"",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/blueprint-tracker.cjs\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
