{
  "description": "Omniscitus: blueprint tracking + wrap-up reminders",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/blueprint-warn.cjs\"",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/version-check.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "message",
            "message": "[omniscitus] Context is about to be compacted. Run /wrap-up now to preserve session knowledge before it's lost. Also run /blueprint-sync if user-created files may exist."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/blueprint-tracker.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
